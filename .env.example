# Postgres (Neon) connection string. Get this from https://console.neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Giscus (GitHub-Discussions-backed comments). Get these from https://giscus.app
# after enabling Discussions on the GitHub repo.
NEXT_PUBLIC_GISCUS_REPO=HyperCharon/hypervoid
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Auth.js (NextAuth v5)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://YOUR_DOMAIN/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Only this GitHub login is allowed into /admin
ADMIN_GITHUB_LOGIN=HyperCharon

# Optional: if set, cron requests must include `Authorization: Bearer $CRON_SECRET`.
# Vercel automatically injects this header when running cron jobs.
# REQUIRED for production — the cron endpoint is unprotected without it.
CRON_SECRET=

# Vercel Blob (image uploads). Auto-injected by Vercel after you create a
# Blob store at Dashboard → Storage → Create → Blob. Only needed locally
# if you want to test uploads on `pnpm dev`.
BLOB_READ_WRITE_TOKEN=

# Umami Cloud analytics. Sign up at https://cloud.umami.is, add the website,
# then copy the data-website-id from the Tracking Code tab.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Override only if you self-host Umami; default uses Umami Cloud's script.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# Resend (email subscription). Get an API key at https://resend.com/api-keys.
# Free tier: 3,000 emails/month, sender defaults to onboarding@resend.dev
# until you verify a custom domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Hypervoid

# Anthropic API (for AI summary + Q&A). Get a key at https://console.anthropic.com/
# Uses Claude Haiku 4.5 by default — pennies per article summary.
ANTHROPIC_API_KEY=

# Site-wide announcement bar (optional). Set ANNOUNCEMENT_MESSAGE to show a
# dismissible banner above the header + a card in the homepage sidebar.
# ANNOUNCEMENT_MESSAGE=欢迎来到 Hypervoid！
# ANNOUNCEMENT_LINK=/posts
# ANNOUNCEMENT_LINK_TEXT=查看文章

# Steam game library (https://steamcommunity.com/dev/apikey)
# STEAM_ID is the 17-digit numeric ID. If only the vanity URL name (the part
# after /id/) is available, set STEAM_VANITY instead and the app resolves it.
# Profile privacy → Game details must be Public to fetch the list.
STEAM_API_KEY=
STEAM_ID=
STEAM_VANITY=
